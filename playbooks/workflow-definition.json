{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "$connections": {
        "defaultValue": {},
        "type": "Object"
      }
    },
    "triggers": {
      "Microsoft_Sentinel_incident": {
        "type": "ApiConnectionWebhook",
        "inputs": {
          "body": {
            "callback_url": "@{listCallbackUrl()}"
          },
          "host": {
            "connection": {
              "name": "@parameters('$connections')['azuresentinel']['connectionId']"
            }
          },
          "path": "/incident-creation"
        }
      }
    },
    "actions": {
      "Envoyer_un_e-mail": {
        "type": "ApiConnection",
        "inputs": {
          "host": {
            "connection": {
              "name": "@parameters('$connections')['outlook']['connectionId']"
            }
          },
          "method": "post",
          "path": "/v2/Mail",
          "body": {
            "To": "ivantonfack53@gmail.com",
            "Subject": "[SENTINEL] Nouvel incident : @{triggerBody()?['object']?['properties']?['title']}",
            "Body": "<p><b>Un incident de securite a ete detecte par Microsoft Sentinel.</b></p><p><b>Titre :</b> @{triggerBody()?['object']?['properties']?['title']}<br><b>Gravite :</b> @{triggerBody()?['object']?['properties']?['severity']}<br><b>Statut :</b> @{triggerBody()?['object']?['properties']?['status']}<br><b>Numero :</b> @{triggerBody()?['object']?['properties']?['incidentNumber']}<br><b>Cree le :</b> @{triggerBody()?['object']?['properties']?['createdTimeUtc']}</p><p><b>Lien :</b> <a href=\"@{triggerBody()?['object']?['properties']?['incidentUrl']}\">Ouvrir l incident dans Sentinel</a></p><hr><p><i>Notification automatique - Playbook SOAR Sentinel</i></p>",
            "Importance": "High"
          }
        }
      }
    }
  },
  "parameters": {
    "$connections": {
      "value": {
        "azuresentinel": {
          "connectionId": "/subscriptions/512817a3-87c7-4af5-a7ea-829b55885255/resourceGroups/rg-sentinel-lab/providers/Microsoft.Web/connections/azuresentinel-pb-notify-incident-email",
          "connectionName": "azuresentinel-pb-notify-incident-email",
          "id": "/subscriptions/512817a3-87c7-4af5-a7ea-829b55885255/providers/Microsoft.Web/locations/francecentral/managedApis/azuresentinel",
          "connectionProperties": {
            "authentication": {
              "type": "ManagedServiceIdentity"
            }
          }
        },
        "outlook": {
          "connectionId": "/subscriptions/512817a3-87c7-4af5-a7ea-829b55885255/resourceGroups/rg-sentinel-lab/providers/Microsoft.Web/connections/outlook",
          "connectionName": "outlook",
          "id": "/subscriptions/512817a3-87c7-4af5-a7ea-829b55885255/providers/Microsoft.Web/locations/francecentral/managedApis/outlook"
        }
      }
    }
  }
}
